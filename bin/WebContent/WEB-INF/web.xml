<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Aadhaar Secure Travel Identity</display-name>
  <description>
    Government identity management system — Aadhaar UID linked to
    passport, driving licence, and travel security with MySQL database.
  </description>

  <!-- ── Welcome page ── -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>

  <!-- ── UTF-8 encoding filter (all requests) ── -->
  <filter>
    <filter-name>EncodingFilter</filter-name>
    <filter-class>com.aadhaar.servlet.EncodingFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>EncodingFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!--
    ── AppStartupListener ──
    Registered here AND via @WebListener annotation.
    Seeds the MySQL database with default rows on first deploy.
    Shuts down the JDBC pool on undeploy / server stop.

    NOTE: Servlets and the listener itself are also registered
    via @WebServlet / @WebListener annotations, so no explicit
    <servlet> / <listener> tags are required below — Tomcat
    auto-scans annotations. The annotation approach is kept
    here for reference.
  -->

  <!--
  <listener>
    <listener-class>com.aadhaar.servlet.AppStartupListener</listener-class>
  </listener>
  -->

  <!-- ── Session config ── -->
  <session-config>
    <session-timeout>60</session-timeout>   <!-- 60 minutes -->
  </session-config>

  <!-- ── Error pages ── -->
  <error-page>
    <error-code>404</error-code>
    <location>/jsp/common/error404.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/jsp/common/error500.jsp</location>
  </error-page>

</web-app>
